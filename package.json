{
  "name": "tabquest",
  "version": "1.0.9",
  "description": "TabQuest: A productivity-focused Open Source Browser extension for managing bookmarks, tasks, and notes with a clean, customizable interface",
  "type": "module",
  "scripts": {
    "dev": "node chooseMode.js dev --host --open",
    "dev:chrome": "vite --mode chrome --host --open",
    "dev:firefox_edge": "vite --mode firefox_edge --host --open",
    "build": "node chooseMode.js build",
    "build:chrome": "vite build --mode chrome",
    "build:firefox_edge": "vite build --mode firefox_edge",
    "test": "node test",
    "test:chrome": "node test",
    "test:firefox_edge": "node test"
  },
  "author": "Mohamed Halith",
  "license": "MIT",
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.30.3"
  },
    "devDependencies": {
        "@babel/core": "^7.28.6",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "autoprefixer": "^10.4.27",
        "babel-jest": "^29.7.0",
        "baseline-browser-mapping": "^2.9.14",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.16",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "@tailwindcss/typography": "^0.5.19",
        "framer-motion": "^12.34.4",
        "lucide-react": "^0.576.0",
        "prompts": "^2.4.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-icons": "^5.4.0",
        "react-markdown": "^10.1.0",
        "react-redux": "^9.2.0"
    }
}
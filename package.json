{
  "name": "tabquest",
  "version": "1.5.0",
  "description": "TabQuest: A productivity-focused Open Source Browser extension for managing bookmarks, tasks, and notes with a clean, customizable interface",
  "type": "module",
  "scripts": {
    "dev": "node chooseMode.js dev",
    "dev:chrome": "node chooseMode.js dev chrome",
    "dev:edge": "node chooseMode.js dev edge",
    "dev:firefox": "node chooseMode.js dev firefox",
    "build": "node chooseMode.js build",
    "build:chrome": "node chooseMode.js build chrome",
    "build:edge": "node chooseMode.js build edge",
    "build:firefox": "node chooseMode.js build firefox",
    "test": "jest",
    "test:chrome": "jest",
    "test:firefox": "jest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "prompts": "^2.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "babel-jest": "^30.3.0",
    "baseline-browser-mapping": "^2.10.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.13.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.30.3"
  }
}
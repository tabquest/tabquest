{
    "manifest_version": 3,
    "name": "DevTab",
    "version": "1.0.1",
    "description": "A developer home page extension",
    "icons": {
        "16": "images/icons/icon16.png",
        "32": "images/icons/icon32.png",
        "48": "images/icons/icon48.png",
        "128": "images/icons/icon128.png"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": ["tabs"],
    "author": "mohamedhalith.smh@gmail.com"
}

{
    "name": "tabquest",
    "version": "1.0.7",
    "description": "TabQuest: A productivity-focused extension for managing bookmarks, tasks, and notes with a clean, customizable interface",
    "type": "module",
    "scripts": {
        "dev": "node chooseMode.js dev --host --open",
        "dev:chrome": "vite --mode chrome --host --open",
        "dev:firefox_edge": "vite --mode firefox_edge --host --open",
        "build": "node chooseMode.js build",
        "build:chrome": "vite build --mode chrome",
        "build:firefox_edge": "vite build --mode firefox_edge",
        "test": "node test",
        "test:chrome": "node test",
        "test:firefox_edge": "node test"
    },
    "author": "Mohamed Halith",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.28.6",
        "@babel/preset-env": "^7.28.6",
        "@babel/preset-react": "^7.26.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.1.0",
        "autoprefixer": "^10.4.23",
        "babel-jest": "^29.7.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "vite": "^6.3.6"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.5.0",
        "@tailwindcss/typography": "^0.5.19",
        "framer-motion": "^12.27.4",
        "lucide-react": "^0.468.0",
        "prompts": "^2.4.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-icons": "^5.4.0",
        "react-markdown": "^10.1.0",
        "react-redux": "^9.2.0"
    }
}
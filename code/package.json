{
    "name": "tabquest",
    "version": "1.0.0",
    "description": "TabQuest: A productivity-focused extension for managing bookmarks, tasks, and notes with a clean, customizable interface",
    "type": "module",
    "scripts": {
        "dev": "node chooseMode.js dev --host --open",
        "dev:chrome": "vite --mode chrome --host --open",
        "dev:firefox_edge": "vite --mode firefox_edge --host --open",
        "build": "node chooseMode.js build",
        "build:chrome": "vite build --mode chrome",
        "build:firefox_edge": "vite build --mode firefox_edge",
        "test": "node chooseMode.js test",
        "test:chrome": "jest --mode chrome",
        "test:firefox_edge": "jest --mode firefox_edge"
    },
    "author": "Mohamed Halith",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-react": "^7.26.3",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "autoprefixer": "^10.4.20",
        "babel-jest": "^29.7.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "vite": "^6.0.2"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.5.0",
        "framer-motion": "^11.15.0",
        "lucide-react": "^0.468.0",
        "prompts": "^2.4.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-icons": "^5.4.0",
        "react-redux": "^9.2.0"
    }
}
